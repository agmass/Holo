{
  "schemaVersion": 1,
  "id": "holo",
  "version": "${version}",
  "name": "Holo",
  "description": "",
  "authors": [],
  "contact": {},
  "license": "LGPL-3.0",
  "icon": "assets/holo/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "org.agmas.holo.client.HoloClient"
    ],
    "main": [
      "org.agmas.holo.Holo"
    ],
    "cardinal-components": [
      "org.agmas.holo.state.HoloComponents"
    ],
    "modmenu": [
      "org.agmas.holo.client.config.HoloModMenuIntergration"
    ],
    "voicechat": [
      "org.agmas.holo.voicechat.HoloVoicechatPlugin"
    ]
  },
  "custom": {
    "cardinal-components": [
      "holo:holo",
      "holo:clone",
      "holo:hololoyalty",
      "holo:style"
    ]
  },
  "mixins": [
    "holo.mixins.json",
    {
      "config": "holo.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "veil": ">=2.5.1",
    "voicechat_api": ">=2.6.0"
  }
}
